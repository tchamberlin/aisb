ARG BASE_IMAGE=localhost/aisb-base:latest
FROM ${BASE_IMAGE}

ARG CLAUDE_VERSION=unknown
# Claude is installed via the upstream curl|bash installer. Accepted as
# standard practice for this vendor; pinning is left to CLAUDE_VERSION as a
# cache-busting key (install.sh fetches latest at build time). Revisit to
# pin via `npm i -g @anthropic-ai/claude-code@${CLAUDE_VERSION}` if the
# TOCTOU window becomes a concern.
RUN echo "claude-code cache key: ${CLAUDE_VERSION}" \
 && bash -lc 'set -euo pipefail; \
      export HOME=/opt/claude-staging; \
      export PATH="$HOME/.local/bin:$PATH"; \
      mkdir -p "$HOME" /opt/claude/bin; \
      curl -fsSL https://claude.ai/install.sh | bash; \
      install -m 0755 "$(readlink -f "$HOME/.local/bin/claude")" /opt/claude/bin/claude; \
      rm -rf /opt/claude-staging'

# Claude's installer records installMethod=native and expects the binary at
# $HOME/.local/bin/claude. Home is a per-run tmpfs, so materialize that
# symlink on each start. Keep the real binary outside /usr/local/bin so
# `claude doctor` doesn't flag it as a competing npm-global install.
RUN printf '%s\n' \
      '#!/bin/sh' \
      'set -e' \
      'mkdir -p "$HOME/.local/bin"' \
      'ln -sfn /opt/claude/bin/claude "$HOME/.local/bin/claude"' \
      'exec /opt/claude/bin/claude "$@"' \
    > /opt/claude/bin/claude-entrypoint \
 && chmod 0755 /opt/claude/bin/claude-entrypoint

ENTRYPOINT ["/opt/claude/bin/claude-entrypoint"]
