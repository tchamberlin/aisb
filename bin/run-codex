#!/usr/bin/env bash
set -euo pipefail
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  [[ "$SCRIPT_SOURCE" == /* ]] || SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"

TOOL="codex"
USER_NAME="codex"
USER_GECOS="Codex"
USER_HOME="/home/codex"

# shellcheck source=bin/_run-common.sh
source "$SCRIPT_DIR/_run-common.sh"
common_init
common_check_image

# Only auth.json + config.toml are shared across repos (OAuth token + user
# config). Everything else (sessions, logs, caches) is scoped per-repo.
mkdir -p "$HOME/.codex"
touch "$HOME/.codex/auth.json"
touch "$HOME/.codex/config.toml"

CODEX_DIR="${STATE_BASE}/codex/${HASH}/dot-codex"
mkdir -p "$CODEX_DIR"

TOOL_MOUNTS=(
  -v "${CODEX_DIR}:${USER_HOME}/.codex:rw,nosuid,nodev,noexec,z"
  -v "${HOME}/.codex/auth.json:${USER_HOME}/.codex/auth.json:${AUTH_MODE},nosuid,nodev,noexec,z"
  -v "${HOME}/.codex/config.toml:${USER_HOME}/.codex/config.toml:${AUTH_MODE},nosuid,nodev,noexec,z"
)

# Container IS the sandbox, so bypass codex's internal one unless opted out.
CODEX_FLAGS=()
if [[ "${CODEX_SAFE_MODE:-0}" != "1" ]]; then
  CODEX_FLAGS+=(--dangerously-bypass-approvals-and-sandbox)
fi

OPENAI_OPTS=()
if [[ -n "${OPENAI_API_KEY:-}" ]]; then
  OPENAI_OPTS+=(-e "OPENAI_API_KEY=$OPENAI_API_KEY")
fi

exec podman run "${COMMON_PODMAN_ARGS[@]}" \
  "${OPENAI_OPTS[@]}" "${TOOL_MOUNTS[@]}" \
  "$IMAGE" "${CODEX_FLAGS[@]}" "$@"
