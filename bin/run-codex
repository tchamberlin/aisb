#!/usr/bin/env bash
set -euo pipefail
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  [[ "$SCRIPT_SOURCE" == /* ]] || SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"

TOOL="codex"
USER_NAME="codex"
USER_HOME="/home/codex"

# shellcheck source=bin/_run-common.sh
source "$SCRIPT_DIR/_run-common.sh"
common_init

common_require_mount_path "$HOME/.codex/auth.json" "Codex auth source path"
common_require_mount_path "${USER_HOME}/.codex/auth.json" "Codex auth destination path"
common_require_mount_path "$HOME/.codex/config.toml" "Codex config source path"
common_require_mount_path "${USER_HOME}/.codex/config.toml" "Codex config destination path"

common_check_image

# Only auth.json + config.toml are shared across repos (OAuth token + user
# config). Everything else (sessions, logs, caches) is scoped per-repo.
mkdir -p "$HOME/.codex"
common_ensure_json_object_file "$HOME/.codex/auth.json" "Codex auth"
touch "$HOME/.codex/config.toml"

CODEX_DIR="${STATE_BASE}/codex/${HASH}/dot-codex"
CODEX_HOST_DIR="${STATE_BASE}/codex/${HASH}/host-codex"
mkdir -p "$CODEX_DIR" "$CODEX_HOST_DIR"
CODEX_AUTH_STAGE="${CODEX_HOST_DIR}/auth.json"
CODEX_CONFIG_STAGE="${CODEX_HOST_DIR}/config.toml"
cp -p "$HOME/.codex/auth.json" "$CODEX_AUTH_STAGE"
cp -p "$HOME/.codex/config.toml" "$CODEX_CONFIG_STAGE"
common_ensure_json_object_file "$CODEX_AUTH_STAGE" "Codex staged auth"

common_require_mount_path "$CODEX_DIR" "Codex state source path"
common_require_mount_path "${USER_HOME}/.codex" "Codex state destination path"
common_require_mount_path "$CODEX_AUTH_STAGE" "Codex staged auth source path"
common_require_mount_path "$CODEX_CONFIG_STAGE" "Codex staged config source path"

TOOL_MOUNTS=(
  -v "${CODEX_DIR}:${USER_HOME}/.codex:rw,nosuid,nodev,noexec,z"
  -v "${CODEX_AUTH_STAGE}:${USER_HOME}/.codex/auth.json:${AUTH_MODE},nosuid,nodev,noexec,z"
  -v "${CODEX_CONFIG_STAGE}:${USER_HOME}/.codex/config.toml:${AUTH_MODE},nosuid,nodev,noexec,z"
)

# Container IS the sandbox, so bypass codex's internal one unless opted out.
CODEX_FLAGS=()
if [[ "${CODEX_SAFE_MODE:-0}" != "1" ]]; then
  CODEX_FLAGS+=(--dangerously-bypass-approvals-and-sandbox)
fi

OPENAI_OPTS=()
if [[ -n "${OPENAI_API_KEY:-}" ]]; then
  OPENAI_OPTS+=(-e "OPENAI_API_KEY=$OPENAI_API_KEY")
fi

codex_auth_is_empty() {
  local compact
  compact="$(tr -d '[:space:]' < "$CODEX_AUTH_STAGE")"
  [[ -z "$compact" || "$compact" == "{}" ]]
}

codex_command_allows_unauth() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      -h|--help|-V|--version|help|login|logout|completion)
        return 0
        ;;
    esac
  done
  return 1
}

if [[ "${AISB_QUIET:-0}" != "1" ]]; then
  echo "[aisb:codex] codex state: $CODEX_DIR" >&2
  echo "[aisb:codex] codex auth: $HOME/.codex/auth.json -> $CODEX_AUTH_STAGE -> ${USER_HOME}/.codex/auth.json ($AUTH_MODE)" >&2
  echo "[aisb:codex] codex config: $HOME/.codex/config.toml -> $CODEX_CONFIG_STAGE -> ${USER_HOME}/.codex/config.toml ($AUTH_MODE)" >&2
  if [[ -n "${OPENAI_API_KEY:-}" ]]; then
    echo "[aisb:codex] codex env: forwarding OPENAI_API_KEY" >&2
  else
    echo "[aisb:codex] codex env: OPENAI_API_KEY not set" >&2
  fi
  if [[ "${CODEX_SAFE_MODE:-0}" == "1" ]]; then
    echo "[aisb:codex] codex sandbox: native approvals enabled" >&2
  else
    echo "[aisb:codex] codex sandbox: bypassed with --dangerously-bypass-approvals-and-sandbox" >&2
  fi
fi

if [[ -z "${OPENAI_API_KEY:-}" ]] && codex_auth_is_empty && ! codex_command_allows_unauth "$@"; then
  echo "Error: Codex is not authenticated." >&2
  echo >&2
  echo "No OPENAI_API_KEY is set and $HOME/.codex/auth.json has no account credentials." >&2
  echo "Run one of:" >&2
  echo "  CODEX_AUTH_WRITE=1 codex login --device-auth" >&2
  echo "  export OPENAI_API_KEY=..." >&2
  exit 1
fi

set +e
podman run "${COMMON_PODMAN_ARGS[@]}" \
  "${OPENAI_OPTS[@]}" "${TOOL_MOUNTS[@]}" \
  "$IMAGE" "${CODEX_FLAGS[@]}" "$@"
status=$?
set -e

if [[ "$AUTH_MODE" == "rw" ]]; then
  cp -p "$CODEX_AUTH_STAGE" "$HOME/.codex/auth.json"
  cp -p "$CODEX_CONFIG_STAGE" "$HOME/.codex/config.toml"
fi

exit "$status"
