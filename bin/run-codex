#!/usr/bin/env bash
set -euo pipefail
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  [[ "$SCRIPT_SOURCE" == /* ]] || SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"

TOOL="codex"
USER_NAME="aisb-$TOOL"
USER_HOME="/home/$USER_NAME"
AISB_MOUNT_USER_HOME_TMPFS=0

# shellcheck source=bin/_run-common.sh
source "$SCRIPT_DIR/_run-common.sh"
common_init

CODEX_HOME_DIR="${STATE_BASE}/codex/${HASH}/home-codex"
mkdir -p "$CODEX_HOME_DIR"

common_require_mount_path "${CODEX_HOME_DIR}" "Codex repo home source path"
common_require_mount_path "${CODEX_HOME_DIR}/.codex" "Codex repo config source path"

common_check_image
common_maybe_warn_tool_update

# Seed per-repo Codex home from host config on first use. After that, Codex
# state belongs to this repo-scoped durable home and survives container removal.
mkdir -p "$HOME/.codex"
common_ensure_json_object_file "$HOME/.codex/auth.json" "Codex auth"
touch "$HOME/.codex/config.toml"
if [[ ! -e "$CODEX_HOME_DIR/.codex" ]]; then
  cp -a "$HOME/.codex" "$CODEX_HOME_DIR/.codex"
fi
mkdir -p "$CODEX_HOME_DIR/.codex"
common_ensure_json_object_file "$CODEX_HOME_DIR/.codex/auth.json" "Codex repo auth"
touch "$CODEX_HOME_DIR/.codex/config.toml"

TOOL_MOUNTS=(
  -v "${CODEX_HOME_DIR}:${USER_HOME}:rw,nosuid,nodev,noexec,z"
)

# Container IS the sandbox, so bypass codex's internal one unless opted out.
CODEX_FLAGS=()
CODEX_FLAGS+=(-c "check_for_update_on_startup=false")
if [[ "${CODEX_SAFE_MODE:-0}" != "1" ]]; then
  CODEX_FLAGS+=(--dangerously-bypass-approvals-and-sandbox)
fi

OPENAI_OPTS=()
if [[ -n "${OPENAI_API_KEY:-}" ]]; then
  OPENAI_OPTS+=(-e "OPENAI_API_KEY=$OPENAI_API_KEY")
fi

codex_auth_is_empty() {
  local compact
  compact="$(tr -d '[:space:]' < "$CODEX_HOME_DIR/.codex/auth.json")"
  [[ -z "$compact" || "$compact" == "{}" ]]
}

codex_command_allows_unauth() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      -h|--help|-V|--version|help|login|logout|completion)
        return 0
        ;;
    esac
  done
  return 1
}

if [[ "${AISB_QUIET:-0}" != "1" ]]; then
  if [[ "${AISB_DEBUG:-0}" == "1" ]]; then
    echo "[aisb:codex:debug] codex home: $CODEX_HOME_DIR -> ${USER_HOME} (rw)" >&2
  fi
  if [[ -n "${OPENAI_API_KEY:-}" ]]; then
    echo "[aisb:codex] codex env: forwarding OPENAI_API_KEY" >&2
  elif [[ "${AISB_DEBUG:-0}" == "1" ]]; then
    echo "[aisb:codex:debug] codex env: OPENAI_API_KEY not set" >&2
  fi
  if [[ "${CODEX_SAFE_MODE:-0}" == "1" ]]; then
    echo "[aisb:codex] codex sandbox: native approvals enabled" >&2
  else
    echo "[aisb:codex] codex sandbox: bypassed with --dangerously-bypass-approvals-and-sandbox" >&2
  fi
  if [[ "${AISB_DEBUG:-0}" == "1" ]]; then
    echo "[aisb:codex:debug] updates: Codex startup update check disabled; use $SCRIPT_DIR/build-containers codex" >&2
  fi
fi

if [[ -z "${OPENAI_API_KEY:-}" ]] && codex_auth_is_empty && ! codex_command_allows_unauth "$@"; then
  echo "Error: Codex is not authenticated." >&2
  echo >&2
  echo "No OPENAI_API_KEY is set and $CODEX_HOME_DIR/.codex/auth.json has no account credentials." >&2
  echo "Run one of:" >&2
  echo "  codex login --device-auth" >&2
  echo "  export OPENAI_API_KEY=..." >&2
  exit 1
fi

exec podman run "${COMMON_PODMAN_ARGS[@]}" \
  "${OPENAI_OPTS[@]}" "${TOOL_MOUNTS[@]}" \
  "$IMAGE" "${CODEX_FLAGS[@]}" "$@"
