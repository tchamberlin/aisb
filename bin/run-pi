#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

TOOL="pi"
USER_NAME="sb"
USER_HOME="/home/sb"
IMAGE="${PI_IMAGE:-pi-uv:latest}"

# shellcheck source=bin/_run-common.sh
source "$SCRIPT_DIR/_run-common.sh"
common_init
common_check_image

# Pi has no persistent host auth file — API keys are forwarded via env.
# State (sessions, logs) lives per-repo under STATE_BASE.
mkdir -p "$HOME/.pi/agent"

PI_DIR="${STATE_BASE}/pi/${HASH}/dot-pi-agent"
mkdir -p "$PI_DIR"

TOOL_MOUNTS=(
  -v "${PI_DIR}:${USER_HOME}/.pi/agent:rw,nosuid,nodev,noexec,z"
)

# Repo-local models.json override — lets a repo pin custom model definitions
# without mutating shared pi state.
PROJECT_MODELS="$ROOT/.pi/agent/models.json"
if [[ -f "$PROJECT_MODELS" ]]; then
  TOOL_MOUNTS+=(-v "${PROJECT_MODELS}:${USER_HOME}/.pi/agent/models.json:ro,nosuid,nodev,noexec,z")
fi

# Forward API keys and editor preferences that pi reads
PI_OPTS=()
for var in ANTHROPIC_API_KEY OPENAI_API_KEY GOOGLE_API_KEY OPENROUTER_API_KEY TOGETHER_API_KEY PI_CODING_AGENT_DIR PI_TELEMETRY PI_CACHE_RETENTION PI_SKIP_VERSION_CHECK VISUAL EDITOR; do
  if [[ -n "${!var:-}" ]]; then
    PI_OPTS+=(-e "${var}=${!var}")
  fi
done

exec podman run "${COMMON_PODMAN_ARGS[@]}" \
  "${PI_OPTS[@]}" "${TOOL_MOUNTS[@]}" \
  "$IMAGE" "$@"
