#!/usr/bin/env bash
set -euo pipefail
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  [[ "$SCRIPT_SOURCE" == /* ]] || SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"

TOOL="pi"
USER_NAME="aisb-$TOOL"
USER_HOME="/home/$USER_NAME"
AISB_MOUNT_USER_HOME_TMPFS=0

# shellcheck source=bin/_run-common.sh
source "$SCRIPT_DIR/_run-common.sh"
common_init

# Repo-local models.json override — lets a repo pin custom model definitions
# without mutating shared pi state.
PROJECT_MODELS="$ROOT/.pi/agent/models.json"
PROJECT_MODELS_ENABLED=0
PROJECT_MODELS_OPTS=""
if [[ -L "$PROJECT_MODELS" ]]; then
  echo "Error: refusing symlinked repo pi models file: $PROJECT_MODELS" >&2
  exit 1
fi
if [[ -f "$PROJECT_MODELS" ]]; then
  PROJECT_MODELS_REAL="$(realpath "$PROJECT_MODELS")"
  if [[ "$PROJECT_MODELS_REAL" != "$ROOT" && "$PROJECT_MODELS_REAL" != "$ROOT"/* ]]; then
    echo "Error: refusing repo pi models file outside workspace: $PROJECT_MODELS -> $PROJECT_MODELS_REAL" >&2
    exit 1
  fi
  common_require_mount_path "$PROJECT_MODELS" "pi models source path"
  common_require_mount_path "${USER_HOME}/.pi/agent/models.json" "pi models destination path"
  PROJECT_MODELS_ENABLED=1
  PROJECT_MODELS_OPTS="ro,nosuid,nodev,noexec"
  if [[ "${AISB_RELABEL_WORKSPACE:-0}" == "1" ]]; then
    PROJECT_MODELS_OPTS+=",z"
  fi
fi

common_check_image

# Pi state lives in a repo-scoped durable home. Seed any host-side state on
# first use, then let the container own that per-repo copy.
mkdir -p "$HOME/.pi/agent"

PI_HOME_DIR="${STATE_BASE}/pi/${HASH}/home-pi"
mkdir -p "$PI_HOME_DIR"
if [[ ! -e "$PI_HOME_DIR/.pi" ]]; then
  cp -a "$HOME/.pi" "$PI_HOME_DIR/.pi"
fi
mkdir -p "$PI_HOME_DIR/.pi/agent"

common_require_mount_path "$PI_HOME_DIR" "pi home source path"
common_require_mount_path "${USER_HOME}/.pi/agent" "pi state destination path"

TOOL_MOUNTS=(
  -v "${PI_HOME_DIR}:${USER_HOME}:rw,nosuid,nodev,noexec,z"
)

if [[ "$PROJECT_MODELS_ENABLED" == "1" ]]; then
  TOOL_MOUNTS+=(-v "${PROJECT_MODELS}:${USER_HOME}/.pi/agent/models.json:${PROJECT_MODELS_OPTS}")
fi

# Forward API keys and editor preferences that pi reads
PI_OPTS=()
PI_FORWARDED_VARS=()
for var in ANTHROPIC_API_KEY OPENAI_API_KEY GOOGLE_API_KEY OPENROUTER_API_KEY TOGETHER_API_KEY PI_CODING_AGENT_DIR PI_TELEMETRY PI_CACHE_RETENTION PI_SKIP_VERSION_CHECK VISUAL EDITOR; do
  if [[ -n "${!var:-}" ]]; then
    PI_OPTS+=(-e "${var}=${!var}")
    PI_FORWARDED_VARS+=("$var")
  fi
done

if [[ "${AISB_QUIET:-0}" != "1" ]]; then
  echo "[aisb:pi] pi home: $PI_HOME_DIR" >&2
  if [[ "$PROJECT_MODELS_ENABLED" == "1" ]]; then
    echo "[aisb:pi] pi models: $PROJECT_MODELS (repo override)" >&2
  else
    echo "[aisb:pi] pi models: default" >&2
  fi
  if ((${#PI_FORWARDED_VARS[@]})); then
    echo "[aisb:pi] pi env: forwarding ${PI_FORWARDED_VARS[*]}" >&2
  else
    echo "[aisb:pi] pi env: no optional vars forwarded" >&2
  fi
fi

exec podman run "${COMMON_PODMAN_ARGS[@]}" \
  "${PI_OPTS[@]}" "${TOOL_MOUNTS[@]}" \
  "$IMAGE" "$@"
