#!/usr/bin/env bash
set -euo pipefail

# Generic sandboxed runner. Executes an arbitrary command inside the
# aisb-base container with the same hardening as run-pi/run-claude/run-codex,
# minus any agent-specific state mounts. Network is enabled.
#
# Usage:
#   run-sb                       # interactive bash
#   run-sb uv run script.py
#   run-sb python3 -c 'print(1)'
#
# Env:
#   SB_IMAGE          override image tag (default: localhost/aisb-base:latest)
#   AISB_NO_NETWORK=1 run with --network=none (defense in depth for untrusted cmds)
#   AISB_MEMORY       memory cap passed to --memory (default: 8g)
#   AISB_CPUS         cpu cap passed to --cpus (default: 4)
#   AISB_PIDS         pid cap passed to --pids-limit (default: 1024)
#   AISB_DEBUG=1      print detailed mount/auth/hardening diagnostics
#   AISB_QUIET=1      suppress startup summary logs

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  [[ "$SCRIPT_SOURCE" == /* ]] || SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"

# shellcheck source=bin/_repo-config.sh
source "$SCRIPT_DIR/_repo-config.sh"

die_dangerous_root() {
  local root="$1"
  echo "Error: refusing to run sb with dangerous workspace root: $root" >&2
  echo >&2
  echo "This wrapper bind-mounts the workspace into a container." >&2
  echo "Run it from a project directory or git repository instead." >&2
  echo "To override intentionally, set AISB_ALLOW_DANGEROUS_ROOT=1." >&2
  exit 1
}

check_workspace_root() {
  local root="$1"
  local home_real xdg_data containers_real dangerous
  dangerous=0

  home_real="$(realpath "$HOME" 2>/dev/null || printf '%s' "$HOME")"
  xdg_data="${XDG_DATA_HOME:-$HOME/.local/share}"
  containers_real="$(realpath "$xdg_data/containers" 2>/dev/null || true)"

  case "$root" in
    /|/bin|/boot|/dev|/etc|/home|/lib|/lib64|/opt|/proc|/root|/run|/sbin|/srv|/sys|/tmp|/usr|/var|/Users)
      dangerous=1
      ;;
  esac

  if [[ "$root" == "$home_real" ]]; then
    dangerous=1
  fi

  if [[ -n "$containers_real" && ( "$root" == "$containers_real" || "$root" == "$containers_real"/* ) ]]; then
    dangerous=1
  fi

  if (( dangerous )); then
    if [[ "${AISB_ALLOW_DANGEROUS_ROOT:-0}" == "1" ]]; then
      echo "warn: AISB_ALLOW_DANGEROUS_ROOT=1; allowing workspace root '$root'" >&2
      return 0
    fi
    die_dangerous_root "$root"
  fi
}

log_startup() {
  [[ "${AISB_QUIET:-0}" == "1" ]] && return 0

  echo "[aisb:sb] workspace: $ROOT (hash=$HASH)" >&2
  echo "[aisb:sb] repo config: $(aisb_repo_config_summary)" >&2
  echo "[aisb:sb] image: $IMAGE ($(aisb_tool_image_source_summary sb))" >&2
  echo "[aisb:sb] limits: memory=$AISB_MEMORY cpus=$AISB_CPUS pids=$AISB_PIDS" >&2

  [[ "${AISB_DEBUG:-0}" == "1" ]] || return 0

  echo "[aisb:sb:debug] container name: $NAME" >&2
  echo "[aisb:sb:debug] workspace mount: $ROOT -> $ROOT ($WORKSPACE_MOUNT_OPTS)" >&2
  echo "[aisb:sb:debug] mount /tmp: $TMP_DIR -> /tmp (bind rw,nosuid,nodev; host filesystem limit)" >&2
  echo "[aisb:sb:debug] mount /home/sb: tmpfs size=256m rw,nosuid,nodev" >&2
  echo "[aisb:sb:debug] mount /uv-bin: tmpfs size=128m rw,nosuid,nodev" >&2
  echo "[aisb:sb:debug] mount /uv-tools: tmpfs size=256m rw,nosuid,nodev" >&2
  echo "[aisb:sb:debug] mount uv cache: $UV_CACHE -> /uv-cache (bind rw,nosuid,nodev)" >&2
  echo "[aisb:sb:debug] mount uv python: $UV_PYTHON_DIR -> /uv-python (bind rw,nosuid,nodev)" >&2
  echo "[aisb:sb:debug] mount venv: $VENV_DIR -> /venv (bind rw,nosuid,nodev)" >&2

  if [[ "${AISB_NO_NETWORK:-0}" == "1" ]]; then
    echo "[aisb:sb:debug] network: disabled" >&2
  else
    echo "[aisb:sb:debug] network: enabled" >&2
  fi

  if [[ "${AISB_RELABEL_WORKSPACE:-0}" == "1" ]]; then
    echo "[aisb:sb:debug] workspace relabel: enabled" >&2
  else
    echo "[aisb:sb:debug] workspace relabel: disabled" >&2
  fi

  echo "[aisb:sb:debug] seccomp: ${SECCOMP_SUMMARY:-podman default}" >&2

  if [[ -n "${GH_TOKEN:-}" ]]; then
    echo "[aisb:sb:debug] gh auth: GH_TOKEN env" >&2
  elif [[ -n "${GITHUB_TOKEN:-}" ]]; then
    echo "[aisb:sb:debug] gh auth: GITHUB_TOKEN env" >&2
  elif [[ -d "$GH_HOST_CONFIG" ]]; then
    echo "[aisb:sb:debug] gh auth: mounted $GH_HOST_CONFIG" >&2
  else
    echo "[aisb:sb:debug] gh auth: none detected" >&2
  fi
}

if git rev-parse --show-toplevel >/dev/null 2>&1; then
  ROOT="$(git rev-parse --show-toplevel)"
else
  ROOT="$PWD"
fi
ROOT="$(realpath "$ROOT")"
check_workspace_root "$ROOT"

BASE="$(aisb_workspace_base "$ROOT")"
HASH="$(aisb_sha1_10 "$ROOT")"
aisb_load_repo_env "$ROOT"
IMAGE="$(aisb_resolve_tool_image sb "$HASH")"
STAMP="$(date +%Y%m%d-%H%M%S)"
NAME="sb-${BASE}-${HASH}-${STAMP}-$$"

if ! podman image exists "$IMAGE" 2>/dev/null; then
  echo "Error: Image '$IMAGE' not found." >&2
  if [[ -n "${AISB_REPO_BASE_IMAGE:-}" && -z "${SB_IMAGE:-}" ]] \
    && ! aisb_repo_base_is_local_containerfile; then
    echo "Build or pull the repo-provided base image, then retry." >&2
  else
    echo "Build it first with:" >&2
    echo "  $(aisb_build_command_hint "$SCRIPT_DIR" "$ROOT" base)" >&2
  fi
  exit 1
fi

CACHE_BASE="${XDG_CACHE_HOME:-$HOME/.cache}/claude-podman"
STATE_BASE="${XDG_STATE_HOME:-$HOME/.local/state}/claude-podman"
UV_CACHE="${CACHE_BASE}/uv/${HASH}"
UV_PYTHON_DIR="${STATE_BASE}/uv-python/${HASH}"
VENV_DIR="${STATE_BASE}/venvs/${HASH}/${STAMP}-$$"
TMP_DIR="${STATE_BASE}/sb/${HASH}/tmp/${STAMP}-$$"
mkdir -p "$UV_CACHE" "$UV_PYTHON_DIR" "$VENV_DIR" "$TMP_DIR"
chmod 1777 "$TMP_DIR"

# Prune per-invocation dirs. Guard against empty path components so a future
# refactor can't let `find` descend into / or $HOME.
if [[ -n "$STATE_BASE" && -n "$HASH" ]]; then
  find "${STATE_BASE}/venvs/${HASH}" -mindepth 1 -maxdepth 1 -type d -mtime +7 -exec rm -rf {} + 2>/dev/null || true
  find "${STATE_BASE}/sb/${HASH}/tmp" -mindepth 1 -maxdepth 1 -type d -mmin +1440 -exec rm -rf {} + 2>/dev/null || true
fi

# Forward common API keys + editor prefs
ENV_OPTS=()
for var in \
    ANTHROPIC_API_KEY OPENAI_API_KEY GOOGLE_API_KEY \
    OPENROUTER_API_KEY TOGETHER_API_KEY GROQ_API_KEY \
    HF_TOKEN QWEN_MODEL \
    VISUAL EDITOR; do
  if [[ -n "${!var:-}" ]]; then
    ENV_OPTS+=(-e "${var}=${!var}")
  fi
done

# GitHub CLI passthrough
GH_OPTS=()
if [[ -n "${GH_TOKEN:-}" ]]; then
  GH_OPTS+=(-e "GH_TOKEN=$GH_TOKEN")
elif [[ -n "${GITHUB_TOKEN:-}" ]]; then
  GH_OPTS+=(-e "GITHUB_TOKEN=$GITHUB_TOKEN")
fi
GH_HOST_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/gh"
if [[ -d "$GH_HOST_CONFIG" ]]; then
  GH_OPTS+=(-v "${GH_HOST_CONFIG}:/home/sb/.config/gh:ro,nosuid,nodev,noexec")
fi

# Interactive only if stdin is a tty
TTY_OPTS=(-i)
if [[ -t 0 ]]; then
  TTY_OPTS+=(-t)
fi

if (( $# == 0 )); then
  set -- bash
fi

# Resource caps (overridable via env)
: "${AISB_MEMORY:=8g}"
: "${AISB_CPUS:=4}"
: "${AISB_PIDS:=1024}"

# Warn if the host has less available memory than AISB_MEMORY; podman will
# honor the cap but the kernel may reap the container under real pressure.
if [[ -r /proc/meminfo ]] && [[ "$AISB_MEMORY" =~ ^([0-9]+)([bBkKmMgG]?)$ ]]; then
  _n="${BASH_REMATCH[1]}"
  case "${BASH_REMATCH[2],,}" in
    ""|b) _req_mem="$_n" ;;
    k)    _req_mem=$((_n * 1024)) ;;
    m)    _req_mem=$((_n * 1024 * 1024)) ;;
    g)    _req_mem=$((_n * 1024 * 1024 * 1024)) ;;
  esac
  _avail_mem="$(awk '/^MemAvailable:/{print $2*1024; exit}' /proc/meminfo)"
  if [[ -n "${_req_mem:-}" && -n "$_avail_mem" ]] && (( _req_mem > _avail_mem )); then
    echo "warn: AISB_MEMORY=$AISB_MEMORY exceeds host MemAvailable (~$((_avail_mem/1024/1024)) MiB); container may OOM" >&2
  fi
fi

NET_OPTS=()
if [[ "${AISB_NO_NETWORK:-0}" == "1" ]]; then
  NET_OPTS+=(--network=none)
fi

WORKSPACE_MOUNT_OPTS="rw,nosuid,nodev"
if [[ "${AISB_RELABEL_WORKSPACE:-0}" == "1" ]]; then
  WORKSPACE_MOUNT_OPTS+=",z"
fi

# Optional: extra seccomp denies on top of podman's default profile
SECCOMP_OPTS=()
SECCOMP_SUMMARY="podman default"
if [[ "${AISB_STRICT_SECCOMP:-0}" == "1" ]]; then
  REPO_ROOT="$(dirname "$SCRIPT_DIR")"
  SECCOMP_PROFILE="${AISB_SECCOMP_PROFILE:-$REPO_ROOT/seccomp-strict.json}"
  if [[ -r "$SECCOMP_PROFILE" ]]; then
    SECCOMP_OPTS+=(--security-opt "seccomp=$SECCOMP_PROFILE")
    SECCOMP_SUMMARY="$SECCOMP_PROFILE"
  else
    echo "warn: AISB_STRICT_SECCOMP=1 but $SECCOMP_PROFILE is not readable; using default" >&2
  fi
fi

log_startup

exec podman run --rm "${TTY_OPTS[@]}" --pull=never \
  --name "$NAME" \
  --userns=keep-id \
  --passwd-entry "sb:x:\$UID:\$GID:sb:/home/sb:/bin/bash" \
  --cap-drop=all \
  --security-opt no-new-privileges \
  --read-only \
  --memory="$AISB_MEMORY" \
  --cpus="$AISB_CPUS" \
  --pids-limit="$AISB_PIDS" \
  "${NET_OPTS[@]}" \
  "${SECCOMP_OPTS[@]}" \
  --tmpfs /home/sb:rw,nosuid,nodev,size=256m,mode=1777 \
  --tmpfs /uv-bin:rw,nosuid,nodev,size=128m,mode=1777 \
  --tmpfs /uv-tools:rw,nosuid,nodev,size=256m,mode=1777 \
  --label "io.aisb.repo=$ROOT" \
  --label "io.aisb.repo_hash=$HASH" \
  --label "io.aisb.session=$STAMP-$$" \
  -e HOME=/home/sb \
  -e TERM="${TERM:-xterm-256color}" \
  -e COLORTERM="${COLORTERM:-truecolor}" \
  -e TMPDIR=/tmp \
  -e TMP=/tmp \
  -e TEMP=/tmp \
  -e UV_CACHE_DIR=/uv-cache \
  -e UV_PYTHON_INSTALL_DIR=/uv-python \
  -e UV_PROJECT_ENVIRONMENT=/venv \
  -e MPLCONFIGDIR=/tmp/mpl \
  -e XDG_CONFIG_HOME=/tmp/xdg-config \
  -e XDG_CACHE_HOME=/tmp/xdg-cache \
  "${ENV_OPTS[@]}" \
  "${GH_OPTS[@]}" \
  -v "$ROOT":"$ROOT":"$WORKSPACE_MOUNT_OPTS" \
  -v "$TMP_DIR":/tmp:rw,nosuid,nodev,Z \
  -v "$UV_CACHE":/uv-cache:rw,nosuid,nodev,z \
  -v "$UV_PYTHON_DIR":/uv-python:rw,nosuid,nodev,z \
  -v "$VENV_DIR":/venv:rw,nosuid,nodev,Z \
  -w "$ROOT" \
  "$IMAGE" \
  "$@"
