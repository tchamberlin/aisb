#!/usr/bin/env bash
set -euo pipefail
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  [[ "$SCRIPT_SOURCE" == /* ]] || SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"

TOOL="claude"
USER_NAME="sb"
USER_HOME="/home/sb"

# shellcheck source=bin/_run-common.sh
source "$SCRIPT_DIR/_run-common.sh"
common_init

common_require_mount_path "$HOME/.claude.json" "Claude host config source path"
common_require_mount_path "${USER_HOME}/.claude.json" "Claude host config destination path"
common_require_mount_path "$HOME/.claude/settings.json" "Claude settings source path"
common_require_mount_path "${USER_HOME}/.claude/settings.json" "Claude settings destination path"
common_require_mount_path "$HOME/.claude/.credentials.json" "Claude credentials source path"
common_require_mount_path "${USER_HOME}/.claude/.credentials.json" "Claude credentials destination path"

common_check_image

# Ensure host-side files exist. .credentials.json is bind-mounted rw so OAuth
# token rotation persists to the host; settings.json is bind-mounted ro so host
# edits propagate immediately and the container cannot mutate it. .claude.json
# and the rest of .claude are snapshotted per-repo below to contain
# prompt-injected config mutations.
touch "$HOME/.claude.json"
mkdir -p "$HOME/.claude"
touch "$HOME/.claude/.credentials.json"
touch "$HOME/.claude/settings.json"

CLAUDE_DIR="${STATE_BASE}/claude/${HASH}/dot-claude"
mkdir -p "$CLAUDE_DIR"
# Placeholder target for the settings.json file bind-mount below.
touch "$CLAUDE_DIR/settings.json"

common_require_mount_path "$CLAUDE_DIR" "Claude state source path"
common_require_mount_path "${USER_HOME}/.claude" "Claude state destination path"
common_require_mount_path "${CLAUDE_DIR}/claude.json" "Claude repo config source path"

# Seed per-repo .claude.json from host on first run, else create an empty
# placeholder so the bind-mount target exists.
if [[ ! -e "$CLAUDE_DIR/claude.json" ]]; then
  if [[ -s "$HOME/.claude.json" ]]; then
    cp -p "$HOME/.claude.json" "$CLAUDE_DIR/claude.json"
  else
    : > "$CLAUDE_DIR/claude.json"
  fi
fi

TOOL_MOUNTS=(
  -v "${CLAUDE_DIR}:${USER_HOME}/.claude:rw,nosuid,nodev,noexec,z"
  -v "${CLAUDE_DIR}/claude.json:${USER_HOME}/.claude.json:rw,nosuid,nodev,noexec,z"
  -v "${HOME}/.claude/settings.json:${USER_HOME}/.claude/settings.json:ro,nosuid,nodev,noexec"
  -v "${HOME}/.claude/.credentials.json:${USER_HOME}/.claude/.credentials.json:rw,nosuid,nodev,noexec"
)

CLAUDE_FLAGS=()
if [[ "${CLAUDE_SAFE_MODE:-0}" != "1" ]]; then
  CLAUDE_FLAGS+=(--dangerously-skip-permissions)
fi

if [[ "${AISB_QUIET:-0}" != "1" ]]; then
  echo "[aisb:claude] claude state: $CLAUDE_DIR" >&2
  echo "[aisb:claude] claude credentials: $HOME/.claude/.credentials.json (rw)" >&2
  echo "[aisb:claude] claude settings: $HOME/.claude/settings.json (ro)" >&2
  if [[ "${CLAUDE_SAFE_MODE:-0}" == "1" ]]; then
    echo "[aisb:claude] claude permissions: native prompts enabled" >&2
  else
    echo "[aisb:claude] claude permissions: bypassed with --dangerously-skip-permissions" >&2
  fi
fi

exec podman run "${COMMON_PODMAN_ARGS[@]}" "${TOOL_MOUNTS[@]}" \
  "$IMAGE" "${CLAUDE_FLAGS[@]}" "$@"
