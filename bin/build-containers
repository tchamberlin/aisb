#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   build-containers [--no-cache] [base|claude|codex|pi|all]
#
# Defaults to `all` when called with no argument. For `all`, the base is
# built first and then the three flavor images build in parallel by default.
# Output from parallel builds is prefixed with [flavor] so lines stay
# attributable.
#
# Env vars:
#   CLAUDE_NO_CACHE=1       pass --no-cache to podman build
#   AISB_BUILD_SEQUENTIAL=1 build claude/codex/pi sequentially for `all`
#   BASE_IMAGE              override base image tag (default: localhost/aisb-base:latest)
#   AISB_WORKSPACE          workspace root to inspect for .aisb.env (default: cwd git root)
#
# Each flavor's image tag matches what the run-* wrappers expect:
#   base    -> localhost/aisb-base:latest, repo-provided AISB_BASE_IMAGE,
#              or localhost/aisb-<repo-name>-<repo-hash>:latest for a project Containerfile
#   claude  -> aisb-claude:latest, or localhost/aisb-claude-<repo-hash>:latest
#   codex   -> aisb-codex:latest, or localhost/aisb-codex-<repo-hash>:latest
#   pi      -> aisb-pi:latest, or localhost/aisb-pi-<repo-hash>:latest

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

# shellcheck source=bin/_repo-config.sh
source "$SCRIPT_DIR/_repo-config.sh"

usage() {
  cat <<'EOF'
Usage:
  build-containers [--no-cache] [base|claude|codex|pi|all]

Options:
  --no-cache   Pass --no-cache to podman build
  -h, --help   Show this help
EOF
}

NO_CACHE=0
FLAVOR="all"
FLAVOR_SET=0
while (($#)); do
  case "$1" in
    --no-cache)
      NO_CACHE=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      if (($# == 0)); then
        break
      fi
      if ((FLAVOR_SET)); then
        echo "error: unexpected argument '$1'" >&2
        usage >&2
        exit 2
      fi
      FLAVOR="$1"
      FLAVOR_SET=1
      shift
      if (($#)); then
        echo "error: unexpected argument '$1'" >&2
        usage >&2
        exit 2
      fi
      break
      ;;
    -*)
      echo "error: unknown option '$1'" >&2
      usage >&2
      exit 2
      ;;
    *)
      if ((FLAVOR_SET)); then
        echo "error: unexpected argument '$1'" >&2
        usage >&2
        exit 2
      fi
      FLAVOR="$1"
      FLAVOR_SET=1
      ;;
  esac
  shift
done

case "$FLAVOR" in
  base|claude|codex|pi|all)
    ;;
  *)
    echo "error: unknown flavor '$FLAVOR' (expected: base|claude|codex|pi|all)" >&2
    usage >&2
    exit 2
    ;;
esac

if [[ -n "${AISB_WORKSPACE:-}" ]]; then
  WORKSPACE_ROOT="$AISB_WORKSPACE"
elif git rev-parse --show-toplevel >/dev/null 2>&1; then
  WORKSPACE_ROOT="$(git rev-parse --show-toplevel)"
else
  WORKSPACE_ROOT="$PWD"
fi
WORKSPACE_ROOT="$(realpath "$WORKSPACE_ROOT")"
WORKSPACE_HASH="$(aisb_sha1_10 "$WORKSPACE_ROOT")"
aisb_load_repo_env "$WORKSPACE_ROOT"

maybe_prompt_persist_repo_base_image() {
  [[ -z "${BASE_IMAGE:-}" ]] || return 0
  [[ -n "${AISB_REPO_CONTAINERFILE:-}" ]] || return 0
  [[ "${AISB_REPO_ENV_HAS_BASE_IMAGE:-0}" != "1" ]] || return 0

  local env_file="$AISB_REPO_ENV_FILE"
  local action="Create"
  if [[ -f "$env_file" ]]; then
    action="Update"
  fi

  if [[ ! -t 0 || ! -t 1 ]]; then
    echo "Detected project Containerfile: $AISB_REPO_CONTAINERFILE"
    echo "Using repo base image: $AISB_REPO_BASE_IMAGE"
    echo "To persist this choice, add AISB_BASE_IMAGE=$AISB_REPO_BASE_IMAGE to $env_file"
    return 0
  fi

  local reply
  printf 'Detected project Containerfile: %s\n' "$AISB_REPO_CONTAINERFILE"
  printf '%s %s with AISB_BASE_IMAGE=%s? [y/N] ' "$action" "$env_file" "$AISB_REPO_BASE_IMAGE"
  read -r reply || reply=""
  case "$reply" in
    y|Y|yes|Yes|YES)
      ;;
    *)
      echo "Using repo base image for this run: $AISB_REPO_BASE_IMAGE"
      return 0
      ;;
  esac

  aisb_append_repo_base_image "$WORKSPACE_ROOT" "$AISB_REPO_BASE_IMAGE"
  echo "Wrote $env_file"
  AISB_REPO_ENV_HAS_BASE_IMAGE=1
}

maybe_prompt_persist_repo_base_image

BASE_IMAGE_EXPLICIT=0
if [[ -n "${BASE_IMAGE:-}" ]]; then
  BASE_IMAGE_EXPLICIT=1
  BASE_IMAGE_TAG="$BASE_IMAGE"
elif [[ -n "${AISB_REPO_BASE_IMAGE:-}" ]]; then
  BASE_IMAGE_TAG="$AISB_REPO_BASE_IMAGE"
else
  BASE_IMAGE_TAG="localhost/aisb-base:latest"
fi

REPO_SCOPED_TOOL_IMAGES=0
if [[ -n "${AISB_REPO_BASE_IMAGE:-}" ]]; then
  REPO_SCOPED_TOOL_IMAGES=1
fi

COMMON_FLAGS=()
if [[ "$NO_CACHE" == "1" || "${CLAUDE_NO_CACHE:-0}" == "1" ]]; then
  COMMON_FLAGS+=(--no-cache)
fi

repo_base_is_local_containerfile() {
  [[ "$BASE_IMAGE_EXPLICIT" != "1" ]] && aisb_repo_base_is_local_containerfile
}

resolve_npm_version() {
  local pkg="$1"
  local version
  if ! version="$(NPM_CONFIG_FUND=false NPM_CONFIG_UPDATE_NOTIFIER=false npm view "$pkg" version 2>/dev/null)" || [[ -z "$version" ]]; then
    echo "error: could not resolve npm version for $pkg (is npm installed and online?)" >&2
    return 1
  fi
  printf '%s' "$version"
}

image_label() {
  local image="$1"
  local label="$2"
  podman image inspect --format "{{if .Config.Labels}}{{index .Config.Labels \"$label\"}}{{end}}" "$image" 2>/dev/null || true
}

managed_base_image_is_stale() {
  local actual_recipe expected_recipe

  if [[ -n "${AISB_REPO_BASE_IMAGE:-}" && "$BASE_IMAGE_EXPLICIT" != "1" ]] \
    && ! repo_base_is_local_containerfile; then
    return 1
  fi

  if ! podman image exists "$BASE_IMAGE_TAG"; then
    return 0
  fi

  actual_recipe="$(image_label "$BASE_IMAGE_TAG" "io.aisb.recipe_fingerprint")"
  expected_recipe="$(aisb_expected_recipe_fingerprint "$REPO_ROOT" "$WORKSPACE_ROOT" base)"

  [[ -z "$actual_recipe" || "$actual_recipe" != "$expected_recipe" ]]
}

ensure_base_image() {
  if podman image exists "$BASE_IMAGE_TAG" && ! managed_base_image_is_stale; then
    return 0
  fi

  if [[ -n "${AISB_REPO_BASE_IMAGE:-}" && "$BASE_IMAGE_EXPLICIT" != "1" ]] \
    && ! repo_base_is_local_containerfile; then
    echo "error: repo base image '$BASE_IMAGE_TAG' from $WORKSPACE_ROOT/.aisb.env was not found" >&2
    echo "Build or pull that image first, then retry." >&2
    return 1
  fi

  if podman image exists "$BASE_IMAGE_TAG"; then
    echo "Base image '$BASE_IMAGE_TAG' is stale; rebuilding it first."
  else
    echo "Base image '$BASE_IMAGE_TAG' not found; building it first."
  fi
  build_one base
}

build_one() {
  local flavor="$1"
  local containerfile="$REPO_ROOT/Containerfile.$flavor"
  local build_context="$REPO_ROOT"

  if [[ "$flavor" == "base" ]] && repo_base_is_local_containerfile; then
    containerfile="$AISB_REPO_CONTAINERFILE"
    build_context="$WORKSPACE_ROOT"
  fi

  if [[ ! -f "$containerfile" ]]; then
    echo "error: $containerfile not found" >&2
    return 1
  fi

  local -a flags=("${COMMON_FLAGS[@]}")
  local tag recipe_fingerprint base_image_id build_flavor

  build_flavor="$flavor"

  case "$flavor" in
    base)
      tag="$BASE_IMAGE_TAG"
      build_flavor="base"
      if [[ -n "${AISB_REPO_BASE_IMAGE:-}" && "$BASE_IMAGE_EXPLICIT" != "1" ]] \
        && ! repo_base_is_local_containerfile; then
        if ! podman image exists "$BASE_IMAGE_TAG"; then
          echo "error: repo base image '$BASE_IMAGE_TAG' from $WORKSPACE_ROOT/.aisb.env was not found" >&2
          echo "Build or pull that image first, then retry." >&2
          return 1
        fi
        echo "Using repo-provided base image: $BASE_IMAGE_TAG"
        return 0
      fi
      if repo_base_is_local_containerfile; then
        echo "Using project Containerfile as repo base: $AISB_REPO_CONTAINERFILE"
      fi
      ;;
    claude)
      if [[ "$REPO_SCOPED_TOOL_IMAGES" == "1" ]]; then
        tag="$(aisb_derived_tool_image claude "$WORKSPACE_HASH")"
      else
        tag="aisb-claude:latest"
      fi
      flags+=(--build-arg "BASE_IMAGE=$BASE_IMAGE_TAG")
      ensure_base_image
      base_image_id="$(podman image inspect --format '{{.Id}}' "$BASE_IMAGE_TAG")"
      local claude_version
      claude_version="$(resolve_npm_version @anthropic-ai/claude-code)"
      echo "Latest Claude Code version: $claude_version"
      flags+=(--build-arg "CLAUDE_VERSION=$claude_version")
      ;;
    codex)
      if [[ "$REPO_SCOPED_TOOL_IMAGES" == "1" ]]; then
        tag="$(aisb_derived_tool_image codex "$WORKSPACE_HASH")"
      else
        tag="aisb-codex:latest"
      fi
      flags+=(--build-arg "BASE_IMAGE=$BASE_IMAGE_TAG")
      ensure_base_image
      base_image_id="$(podman image inspect --format '{{.Id}}' "$BASE_IMAGE_TAG")"
      local codex_version
      codex_version="$(resolve_npm_version @openai/codex)"
      echo "Latest Codex version: $codex_version"
      flags+=(--build-arg "CODEX_VERSION=$codex_version")
      ;;
    pi)
      if [[ "$REPO_SCOPED_TOOL_IMAGES" == "1" ]]; then
        tag="$(aisb_derived_tool_image pi "$WORKSPACE_HASH")"
      else
        tag="aisb-pi:latest"
      fi
      flags+=(--build-arg "BASE_IMAGE=$BASE_IMAGE_TAG")
      ensure_base_image
      base_image_id="$(podman image inspect --format '{{.Id}}' "$BASE_IMAGE_TAG")"
      local pi_version
      pi_version="$(resolve_npm_version @mariozechner/pi-coding-agent)"
      echo "Latest pi-coding-agent version: $pi_version"
      flags+=(--build-arg "PI_VERSION=$pi_version")
      ;;
    *)
      echo "error: unknown flavor '$flavor' (expected: base|claude|codex|pi|all)" >&2
      return 2
      ;;
  esac

  recipe_fingerprint="$(aisb_expected_recipe_fingerprint "$REPO_ROOT" "$WORKSPACE_ROOT" "$build_flavor")"
  flags+=(
    --label "io.aisb.managed=true"
    --label "io.aisb.flavor=$build_flavor"
    --label "io.aisb.recipe_fingerprint=$recipe_fingerprint"
  )
  if [[ -n "${base_image_id:-}" ]]; then
    flags+=(--label "io.aisb.base_image_id=$base_image_id")
  fi

  echo "Building $tag from $containerfile"
  podman build \
    "${flags[@]}" \
    -t "$tag" \
    -f "$containerfile" \
    "$build_context"
}

build_all_sequential() {
  local f
  for f in claude codex pi; do
    build_one "$f"
  done
}

build_all_parallel() {
  local -a pids=()
  local -a labels=()
  local f fail i

  for f in claude codex pi; do
    (build_one "$f" 2>&1 | sed -u "s/^/[$f] /") &
    pids+=($!)
    labels+=("$f")
  done

  fail=0
  for i in "${!pids[@]}"; do
    if ! wait "${pids[$i]}"; then
      echo "build failed: ${labels[$i]}" >&2
      fail=$((fail + 1))
    fi
  done

  if (( fail > 0 )); then
    echo "$fail flavor build(s) failed" >&2
    return 1
  fi
}

case "$FLAVOR" in
  all)
    build_one base
    if [[ "${AISB_BUILD_SEQUENTIAL:-0}" == "1" ]]; then
      build_all_sequential
    else
      build_all_parallel
    fi
    ;;
  *)
    build_one "$FLAVOR"
    ;;
esac
