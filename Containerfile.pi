ARG BASE_IMAGE=localhost/aisb-base:latest
FROM ${BASE_IMAGE}

COPY --chmod=0755 container/check-tool-prereqs.sh /usr/local/bin/aisb-check-tool-prereqs
RUN /usr/local/bin/aisb-check-tool-prereqs pi npm \
 && rm /usr/local/bin/aisb-check-tool-prereqs

ARG PI_VERSION=unknown
RUN echo "pi-coding-agent version: ${PI_VERSION}" \
 && test "${PI_VERSION}" != "unknown" \
 && npm install -g "@mariozechner/pi-coding-agent@${PI_VERSION}" \
 && rm -rf "$NPM_CONFIG_CACHE"

ENTRYPOINT ["pi"]
