ARG BASE_IMAGE=localhost/aisb-base:latest
FROM ${BASE_IMAGE}

COPY --chmod=0755 container/install-download-tools.sh /usr/local/bin/aisb-install-download-tools
COPY --chmod=0755 container/install-node-npm.sh /usr/local/bin/aisb-install-node-npm
RUN /usr/local/bin/aisb-install-node-npm \
 && rm /usr/local/bin/aisb-install-node-npm /usr/local/bin/aisb-install-download-tools

ARG PI_VERSION=unknown
RUN echo "pi-coding-agent version: ${PI_VERSION}" \
 && test "${PI_VERSION}" != "unknown" \
 && npm install -g "@mariozechner/pi-coding-agent@${PI_VERSION}" \
 && rm -rf "$NPM_CONFIG_CACHE"

ENTRYPOINT ["pi"]
