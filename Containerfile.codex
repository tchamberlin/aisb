ARG BASE_IMAGE=localhost/aisb-base:latest
FROM ${BASE_IMAGE}

ENV NPM_CONFIG_CACHE=/tmp/npm-cache

COPY --chmod=0755 container/install-agent-runtime-deps.sh /usr/local/bin/aisb-install-agent-runtime-deps
COPY --chmod=0755 container/install-node-npm.sh /usr/local/bin/aisb-install-node-npm
RUN /usr/local/bin/aisb-install-agent-runtime-deps \
 && /usr/local/bin/aisb-install-node-npm \
 && rm /usr/local/bin/aisb-install-agent-runtime-deps /usr/local/bin/aisb-install-node-npm

ARG CODEX_VERSION=unknown
RUN echo "codex version: ${CODEX_VERSION}" \
 && test "${CODEX_VERSION}" != "unknown" \
 && npm install -g "@openai/codex@${CODEX_VERSION}" \
 && rm -rf "$NPM_CONFIG_CACHE"

# Codex runs as user "codex" with HOME=/home/codex.
RUN mkdir -p /home/codex && chmod 0777 /home/codex

ENTRYPOINT ["codex"]
